{
  "permissions": {
    "allow": [
      "Bash(python app.py)",
      "Bash(python -m venv venv)",
      "Bash(pip install -r requirements.txt)",
      "Bash(pytest)",
      "Bash(pytest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/*.sqlite)",
      "Read(**/*.db)"
    ]
  },
  "env": {
    "FLASK_ENV": "development"
  }
}
